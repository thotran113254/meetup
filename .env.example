# Site URL (used for SEO canonical URLs, sitemaps, OG images)
NEXT_PUBLIC_SITE_URL=https://yourbrand.com

# Database (PostgreSQL) — auto-configured by init-project.sh
DATABASE_URL=postgresql://goclaw:goclaw@localhost:5432/your_project_db

# API key for AI agent content management (auto-generated by init-project.sh)
API_SECRET_KEY=your-secret-api-key-here

# CORS - comma-separated allowed origins for API
ALLOWED_ORIGINS=https://yourbrand.com

# Dev server port (auto-assigned by init-project.sh)
PORT=3001

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
