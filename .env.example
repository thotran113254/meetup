# Site URL (used for SEO canonical URLs, sitemaps, OG images)
NEXT_PUBLIC_SITE_URL=https://yourbrand.com

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact form (optional)
CONTACT_EMAIL=hello@yourbrand.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/your_db_name

# API key for AI agent content management (protect mutation endpoints)
API_SECRET_KEY=your-secret-api-key-here

# CORS - comma-separated allowed origins for API (optional)
ALLOWED_ORIGINS=https://yourbrand.com
